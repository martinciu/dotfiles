#!/usr/bin/env bash
# Prints a fully-formatted tmux status segment for the current git/worktree
# state, or an empty string if not in a git repo.
#
# Usage: tmux-git-status <pwd> <prev-bg-hex> <next-bg-hex>
#
# Output rules:
#   - not in a git repo                  -> empty
#   - main checkout                      -> chipless,    BRANCH on bar bg
#   - worktree, branch == wt-dir name    -> yellow chip, BRANCH
#   - worktree, branch != wt-dir name    -> yellow chip, BRANCH · wt:WT_NAME
#
# When the working tree has changes or diverges from upstream, compact markers
# are appended in this order:
#   ins/del   inline ratio in lifted/deepened green & red (slash neutral).
#             Collapses to a single colored count when only one side is non-zero.
#   N?        untracked files
#   ↑N        ahead          ↓N   behind
# Insertion/deletion totals come from `git diff --numstat HEAD` (staged +
# unstaged tracked changes). Untracked / ahead / behind inherit the surrounding
# neutral fg — color is reserved for line-change weight.

set -e
pwd_in="${1:-$PWD}"
prev_bg="${2:-#073642}"
next_bg="${3:-#073642}"

# Solarized base16
fg_text="#073642"          # base02 — dark text on bright chip
bg_wt="#b58900"            # yellow — worktree chip

# Inline change-marker palette, two pairs tuned per background.
fg_ins_bar="#b8d65c"       # lifted green for bar bg
fg_del_bar="#ff7770"       # lifted red   for bar bg
fg_neutral_bar="#93a1a1"   # base1
fg_ins_wt="#3a5400"        # deepened green for yellow chip
fg_del_wt="#7a1116"        # deepened red   for yellow chip
fg_neutral_wt="#073642"    # base02 — same as branch text on yellow

# Nerd Font / unicode glyphs as UTF-8 byte sequences (avoids editor-dependent literal embedding)
icon=$(printf '\xef\x84\xa6')      # U+F126 nf-fa-code_branch
tri_l=$(printf '\xee\x82\xb6')     # U+E0B6 powerline rounded left cap (filled)
tri_r=$(printf '\xee\x82\xb4')     # U+E0B4 powerline rounded right cap (filled)
g_up=$(printf '\xe2\x86\x91')      # U+2191 ↑ (ahead)
g_dn=$(printf '\xe2\x86\x93')      # U+2193 ↓ (behind)

cd "$pwd_in" 2>/dev/null || exit 0

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || \
  branch=$(git rev-parse --short HEAD 2>/dev/null) || \
  exit 0

git_dir=$(git rev-parse --git-dir 2>/dev/null)
common_dir=$(git rev-parse --git-common-dir 2>/dev/null)

if [ "$git_dir" != "$common_dir" ]; then
  is_worktree=1
  bg=$bg_wt
  branch_fg=$fg_text
  ins_fg=$fg_ins_wt
  del_fg=$fg_del_wt
  neutral_fg=$fg_neutral_wt
  wt=$(basename "$(git rev-parse --show-toplevel)")
  if [ "$wt" = "$branch" ]; then
    label="$icon $branch"
  else
    label="$icon $branch · wt:$wt"
  fi
else
  is_worktree=0
  bg="#073642"             # bar bg — chipless on main
  branch_fg=$fg_neutral_bar
  ins_fg=$fg_ins_bar
  del_fg=$fg_del_bar
  neutral_fg=$fg_neutral_bar
  label="$icon $branch"
fi

# Untracked file count + upstream divergence from porcelain v2. The
# `# branch.ab` line only appears when the branch has an upstream, so we
# default ahead/behind to zero and stay silent for branches without one.
ahead=0; behind=0; untracked=0
if status_out=$(git status --porcelain=v2 --branch 2>/dev/null); then
  while IFS= read -r line; do
    case "$line" in
      "# branch.ab "*)
        set -- $line
        ahead=${3#+}
        behind=${4#-}
        ;;
      "? "*)
        untracked=$((untracked+1))
        ;;
    esac
  done <<< "$status_out"
fi

# Total inserted/deleted lines across staged + unstaged tracked changes.
# Binary files render as `-\t-` in numstat — skip them rather than treat as 0.
ins=0; del=0
if numstat=$(git diff --numstat HEAD 2>/dev/null); then
  while IFS=$'\t' read -r a d _; do
    if [ -z "$a" ]; then continue; fi
    if [ "$a" = "-" ] || [ "$d" = "-" ]; then continue; fi
    ins=$((ins + a))
    del=$((del + d))
  done <<< "$numstat"
fi

# Ins/del token: ratio when both, single colored count when only one, empty
# otherwise. Each token resets fg back to branch_fg so the following markers
# (untracked / ahead / behind) inherit the correct neutral.
diff_token=""
if [ "$ins" -gt 0 ] && [ "$del" -gt 0 ]; then
  diff_token=" #[fg=${ins_fg}]${ins}#[fg=${neutral_fg}]/#[fg=${del_fg}]${del}#[fg=${branch_fg}]"
elif [ "$ins" -gt 0 ]; then
  diff_token=" #[fg=${ins_fg}]${ins}#[fg=${branch_fg}]"
elif [ "$del" -gt 0 ]; then
  diff_token=" #[fg=${del_fg}]${del}#[fg=${branch_fg}]"
fi

extras="$diff_token"
if [ "$untracked" -gt 0 ]; then extras="$extras ${untracked}?";   fi
if [ "$ahead"     -gt 0 ]; then extras="$extras ${g_up}${ahead}"; fi
if [ "$behind"    -gt 0 ]; then extras="$extras ${g_dn}${behind}"; fi
label="$label$extras"

# Worktree path: rounded chip with both caps. Main path: chipless — emit only
# the leading cap (visually closes the preceding chip) followed by the label.
if [ "$is_worktree" = 1 ]; then
  printf '#[fg=%s,bg=%s]%s#[fg=%s,bg=%s] %s #[fg=%s,bg=%s]%s' \
    "$bg" "$prev_bg" "$tri_l" \
    "$branch_fg" "$bg" \
    "$label" \
    "$bg" "$next_bg" "$tri_r"
else
  printf '#[fg=%s,bg=%s]%s#[fg=%s,bg=%s] %s' \
    "$bg" "$prev_bg" "$tri_l" \
    "$branch_fg" "$bg" \
    "$label"
fi
