#!/usr/bin/env bash
# tmux-sesh-popup — fzf-driven session switcher rooted at $PROJECTS_HOME.
# Lists every top-level dir under PROJECTS_HOME, plus existing tmux sessions
# (deduped). Picked entry is handed to `sesh connect` which attaches an
# existing session or creates a new one rooted at the chosen path.
set -eu

projects="$PROJECTS_HOME"

# Project dirs (full path, one per line)
project_paths=$(find "$projects" -mindepth 1 -maxdepth 1 -type d ! -name '.*' \
  -print 2>/dev/null | sort)

# Pre-existing tmux sessions (just the name) so we can resume in-flight work
session_names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

selected=$(
  {
    printf '%s\n' "$session_names"
    printf '%s\n' "$project_paths"
  } \
  | awk 'NF && !seen[$0]++' \
  | fzf --reverse --no-sort --border --border-label=' sesh ' \
        --prompt='> ' \
        --with-nth=-1 --delimiter=/
) || exit 0

[ -n "$selected" ] && exec sesh connect "$selected"
